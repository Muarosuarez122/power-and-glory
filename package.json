{
  "name": "role",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "npm run build && node server.js",
    "package-win": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.antigravity.podergloria",
    "productName": "Poder y Gloria",
    "directories": {
      "output": "release-final"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "package.json",
      "icon.png",
      "node_modules/**/*"
    ],
    "win": {
      "target": "zip",
      "asar": true
    }
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "puppeteer": "^24.40.0",
    "vite": "^8.0.4"
  },
  "dependencies": {
    "express": "^5.2.1",
    "peer": "^1.0.2",
    "peerjs": "^1.5.5"
  }
}
